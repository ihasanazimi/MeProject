<?xml version="1.0" encoding="utf-8"?>
<resources>


    <declare-styleable name="ToggleImageView">
        <attr name="src_checked" format="reference" />
        <attr name="src_unchecked" format="reference" />
    </declare-styleable>


    <declare-styleable name="MaxHeightScrollView">
        <attr name="maxHeight" format="dimension" />
    </declare-styleable>



    <declare-styleable name="RoundedImageView">
        <attr name="riv_cornerSize" format="dimension|reference" />
    </declare-styleable>


    <declare-styleable name="CircleImageView">
        <attr name="src" format="reference"/>
        <attr name="scaleType">
            <enum name="center_crop" value="0"/>
            <enum name="center_inside" value="1"/>
        </attr>
        <attr name="strokeWidth" format="dimension"/>
        <attr name="strokeColor" format="color"/>
        <attr name="cornerRadius" format="dimension"/>
        <attr name="isCircular" format="boolean"/>
    </declare-styleable>


    <declare-styleable name="LoadingButton">
        <attr name="loadingBtnTitle" format="string" />
        <attr name="loadingBtnLoadingTitle" format="string" />
        <attr name="loadingBtnBackgroundColor" format="reference|color"/>
        <attr name="loadingBtnTextColor" format="reference|color"/>
        <attr name="loadingBtnIcon" format="reference"/>
        <attr name="loadingBtnIconTint" format="reference|color"/>
        <attr name="loadingBtnIconSize" format="dimension"/>
        <attr name="loadingBtnIconPadding" format="dimension"/>
        <attr name="loadingBtnGravity" format="enum">
            <enum name="center" value="17"/>
            <enum name="left" value="3"/>
            <enum name="right" value="5"/>
        </attr>
        <attr name="loadingBtnTextGravity" format="enum">
            <enum name="center" value="17"/>
            <enum name="left" value="3"/>
            <enum name="right" value="5"/>
        </attr>
        <attr name="loadingBtnIconGravity" format="enum">
            <enum name="start" value="3"/>
            <enum name="end" value="5"/>
        </attr>
    </declare-styleable>




</resources>