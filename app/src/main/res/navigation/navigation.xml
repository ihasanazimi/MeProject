<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="ir.ha.meproject.presentation.fragments.features.splash.SplashFragment"
        android:label="splashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="ir.ha.meproject.presentation.fragments.features.home.HomeFragment"
        android:label="homeFragment"
        tools:layout="@layout/fragment_home">


        <argument
            android:name="argument"
            app:argType="string"
            app:nullable="true"
            />
        <action
            android:id="@+id/action_homeFragment_to_moreFragment"
            app:destination="@id/moreFragment" />


    </fragment>
    <fragment
        android:id="@+id/moreFragment"
        android:name="ir.ha.meproject.presentation.fragments.features.more.MoreFragment"
        android:label="MoreFragment"
        tools:layout="@layout/fragment_more" >


        <argument
            android:name="argument"
            app:argType="string"
            app:nullable="true"
            />


    </fragment>
</navigation>